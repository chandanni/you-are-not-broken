<link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' fill='%23080B12'/><circle cx='50' cy='50' r='40' fill='none' stroke='%237B2FBE' stroke-width='2'/><circle cx='50' cy='34' r='16' fill='none' stroke='%237B2FBE' stroke-width='1.5'/><circle cx='50' cy='66' r='16' fill='none' stroke='%237B2FBE' stroke-width='1.5'/><circle cx='36.1' cy='42' r='16' fill='none' stroke='%237B2FBE' stroke-width='1.5'/><circle cx='63.9' cy='42' r='16' fill='none' stroke='%237B2FBE' stroke-width='1.5'/><circle cx='36.1' cy='58' r='16' fill='none' stroke='%237B2FBE' stroke-width='1.5'/><circle cx='63.9' cy='58' r='16' fill='none' stroke='%237B2FBE' stroke-width='1.5'/><circle cx='50' cy='50' r='16' fill='none' stroke='%237B2FBE' stroke-width='1.5'/><circle cx='50' cy='50' r='3' fill='%237B2FBE'/></svg>">
<link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;1,400;1,600&family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

/* Font definitions with fallbacks */
:root {
  --font-serif: 'Lora', 'Georgia', 'Times New Roman', serif;
  --font-sans: 'Poppins', 'SF Pro Display', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
}

:root {
  --bg: #FAFAF8;
  --bg2: #F2EFF0;
  --ink: #111110;
  --mid: #4A4845;
  --dim: #7A7775;
  --violet: #7B2FBE;
  --violet-light: #C8A8E8;
  --border: #DDDAD8;
  --box-bg: #F2EEFF;
  --shadow: rgba(0,0,0,0.18);
  --page-shadow: rgba(0,0,0,0.25);
  --page-border: #E8E4E0;
}

.dark {
  --bg: #080B12;
  --bg2: #0D1020;
  --ink: #EDE9E4;
  --mid: #9A9690;
  --dim: #5A5650;
  --violet: #C39BD3;
  --violet-light: #3A2860;
  --border: #1A1E2C;
  --box-bg: #0C0F1C;
  --shadow: rgba(0,0,0,0.6);
  --page-shadow: rgba(0,0,0,0.7);
  --page-border: #0D0B1A;
}

body {
  background: #1a1a2e;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-family: 'Poppins', 'SF Pro Display', '-apple-system', 'BlinkMacSystemFont', sans-serif; font-family: 'Poppins', 'SF Pro Display', '-apple-system', 'BlinkMacSystemFont', sans-serif;
  overflow: hidden;
  position: relative;
}

/* Background ambient */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  background: radial-gradient(ellipse at 20% 50%, rgba(123,47,190,0.15) 0%, transparent 60%),
              radial-gradient(ellipse at 80% 50%, rgba(123,47,190,0.08) 0%, transparent 60%);
  pointer-events: none;
}

/* Controls */
.controls {
  position: fixed;
  top: 20px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  gap: 12px;
  z-index: 100;
  background: rgba(0,0,0,0.4);
  backdrop-filter: blur(12px);
  padding: 8px 16px;
  border-radius: 50px;
  border: 1px solid rgba(255,255,255,0.1);
}

.controls span {
  color: rgba(255,255,255,0.5);
  font-size: 11px;
  letter-spacing: 0.1em;
  font-family: 'Poppins', 'SF Pro Display', '-apple-system', 'BlinkMacSystemFont', sans-serif; font-family: 'Poppins', 'SF Pro Display', '-apple-system', 'BlinkMacSystemFont', sans-serif;
}

.theme-btn {
  background: none;
  border: 1px solid rgba(255,255,255,0.2);
  color: rgba(255,255,255,0.7);
  padding: 4px 12px;
  border-radius: 20px;
  cursor: pointer;
  font-size: 11px;
  font-family: 'Poppins', 'SF Pro Display', '-apple-system', 'BlinkMacSystemFont', sans-serif; font-family: 'Poppins', 'SF Pro Display', '-apple-system', 'BlinkMacSystemFont', sans-serif;
  transition: all 0.2s;
}
.theme-btn:hover { background: rgba(255,255,255,0.1); color: white; }
.theme-btn.active { background: rgba(123,47,190,0.5); border-color: rgba(195,155,211,0.5); color: white; }

/* Page counter */
.page-counter {
  position: fixed;
  bottom: 24px;
  left: 50%;
  transform: translateX(-50%);
  color: rgba(255,255,255,0.4);
  font-size: 11px;
  letter-spacing: 0.15em;
  font-family: 'Poppins', 'SF Pro Display', '-apple-system', 'BlinkMacSystemFont', sans-serif; font-family: 'Poppins', 'SF Pro Display', '-apple-system', 'BlinkMacSystemFont', sans-serif;
  z-index: 100;
}

/* Book container */
.book-wrapper {
  perspective: 2000px;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.book {
  position: relative;
  width: 340px;
  height: 510px;
  transform-style: preserve-3d;
}

/* Nav arrows */
.nav-btn {
  position: fixed;
  top: 50%;
  transform: translateY(-50%);
  background: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.15);
  color: rgba(255,255,255,0.6);
  width: 44px;
  height: 44px;
  border-radius: 50%;
  cursor: pointer;
  font-size: 18px;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  transition: all 0.2s;
  backdrop-filter: blur(8px);
}
.nav-btn:hover { background: rgba(123,47,190,0.3); color: white; border-color: rgba(195,155,211,0.4); }
.nav-btn:active { transform: translateY(-50%) scale(0.95); }
.nav-prev { left: calc(50% - 220px); }
.nav-next { right: calc(50% - 220px); }
.nav-btn:disabled { opacity: 0.2; cursor: default; }
.nav-btn:disabled:hover { background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.6); }

/* Pages */
.page {
  position: absolute;
  width: 340px;
  height: 510px;
  top: 0; left: 0;
  background: var(--page-border);
  border-radius: 3px 12px 12px 3px;
  box-shadow: 4px 0 20px var(--shadow), 0 4px 30px rgba(0,0,0,0.3);
  overflow: hidden;
  transition: transform 0.7s cubic-bezier(0.645, 0.045, 0.355, 1.000), opacity 0.3s;
  transform-origin: left center;
  backface-visibility: hidden;
  display: flex;
  flex-direction: column;
  padding: 10px;
}

.page::before {
  content: '';
  position: absolute;
  inset: 10px;
  border: 0.5px solid var(--violet);
  opacity: 0.2;
  border-radius: 2px;
  pointer-events: none;
  z-index: 5;
}

.page.hidden { display: none; }
.page.flipping-out {
  animation: flipOut 0.6s cubic-bezier(0.645, 0.045, 0.355, 1.000) forwards;
}
.page.flipping-in {
  animation: flipIn 0.6s cubic-bezier(0.645, 0.045, 0.355, 1.000) forwards;
}

@keyframes flipOut {
  0%   { transform: rotateY(0deg); opacity: 1; }
  100% { transform: rotateY(-90deg); opacity: 0; }
}
@keyframes flipIn {
  0%   { transform: rotateY(90deg); opacity: 0; }
  100% { transform: rotateY(0deg); opacity: 1; }
}

/* Book spine shadow */
.book::before {
  content: '';
  position: absolute;
  left: 0; top: 0;
  width: 8px; height: 100%;
  background: linear-gradient(to right, rgba(0,0,0,0.3), transparent);
  z-index: 10;
  border-radius: 3px 0 0 3px;
  pointer-events: none;
}

/* Book edge highlight */
.book::after {
  content: '';
  position: absolute;
  right: -3px; top: 4px;
  width: 3px; height: calc(100% - 8px);
  background: linear-gradient(to bottom, rgba(255,255,255,0.1), rgba(0,0,0,0.2));
  border-radius: 0 2px 2px 0;
}

/* PAGE CONTENT STYLES */
.page-inner {
  flex: 1;
  padding: 26px 20px 18px;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  position: relative;
  background: var(--bg);
  border-radius: 2px;
  z-index: 1;
}

/* COVER PAGE */
.cover-page .page-inner {
  background: var(--bg);
  align-items: center;
  justify-content: center;
  text-align: center;
  gap: 0;
}

.cover-eyebrow {
  font-size: 7px;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: var(--dim);
  font-family: 'Poppins', 'SF Pro Display', '-apple-system', 'BlinkMacSystemFont', sans-serif; font-family: 'Poppins', 'SF Pro Display', '-apple-system', 'BlinkMacSystemFont', sans-serif;
  margin-bottom: 14px;
}

.cover-geo {
  width: 140px;
  height: 140px;
  margin: 0 auto 16px;
}

.cover-title {
  font-family: 'Lora', 'Georgia', 'Times New Roman', serif;
  font-size: 26px;
  font-weight: 400;
  color: var(--ink);
  line-height: 1.25;
  margin-bottom: 10px;
}
.cover-title em { font-style: italic; opacity: 0.5; }

.cover-subtitle {
  font-family: 'Poppins', 'SF Pro Display', '-apple-system', 'BlinkMacSystemFont', sans-serif; font-family: 'Poppins', 'SF Pro Display', '-apple-system', 'BlinkMacSystemFont', sans-serif;
  font-size: 9px;
  font-weight: 300;
  color: var(--mid);
  line-height: 1.7;
  margin-bottom: 20px;
}

.cover-author {
  font-family: 'Poppins', 'SF Pro Display', '-apple-system', 'BlinkMacSystemFont', sans-serif; font-family: 'Poppins', 'SF Pro Display', '-apple-system', 'BlinkMacSystemFont', sans-serif;
  font-size: 9px;
  font-weight: 300;
  color: var(--dim);
  letter-spacing: 0.05em;
}

/* VERSE PAGE */
.verse-page .page-inner {
  align-items: center;
  justify-content: center;
  text-align: center;
  gap: 16px;
}

.verse-geo { width: 100px; height: 100px; margin: 0 auto; }

.verse-text {
  font-family: 'Lora', 'Georgia', 'Times New Roman', serif;
  font-style: italic;
  font-size: 13px;
  color: var(--ink);
  line-height: 1.85;
}

.verse-attr {
  font-family: 'Poppins', 'SF Pro Display', '-apple-system', 'BlinkMacSystemFont', sans-serif; font-family: 'Poppins', 'SF Pro Display', '-apple-system', 'BlinkMacSystemFont', sans-serif;
  font-size: 8px;
  color: var(--dim);
}

/* DEDICATION */
.dedication-page .page-inner {
  align-items: center;
  justify-content: center;
  text-align: center;
  gap: 8px;
}

.ded-for { font-family: 'Lora', 'Georgia', 'Times New Roman', serif; font-style: italic; font-size: 12px; color: var(--dim); }
.ded-name { font-family: 'Lora', 'Georgia', 'Times New Roman', serif; font-size: 20px; color: var(--ink); margin-bottom: 16px; }
.ded-egg { font-size: 42px; display: block; text-align: center; margin: 0 auto 14px; }
.ded-note { font-family: 'Lora', 'Georgia', 'Times New Roman', serif; font-style: italic; font-size: 10px; color: var(--mid); line-height: 1.7; max-width: 200px; }

/* FOREWORD / CHAPTER HEADER */
.section-label {
  font-family: 'Poppins', 'SF Pro Display', '-apple-system', 'BlinkMacSystemFont', sans-serif; font-family: 'Poppins', 'SF Pro Display', '-apple-system', 'BlinkMacSystemFont', sans-serif;
  font-size: 7px;
  font-weight: 600;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: var(--violet);
  margin-bottom: 6px;
}

.page-title {
  font-family: 'Lora', 'Georgia', 'Times New Roman', serif;
  font-size: 20px;
  font-weight: 400;
  color: var(--ink);
  line-height: 1.2;
  margin-bottom: 5px;
}
.page-title em { font-style: italic; }

.page-tagline {
  font-family: 'Poppins', 'SF Pro Display', '-apple-system', 'BlinkMacSystemFont', sans-serif; font-family: 'Poppins', 'SF Pro Display', '-apple-system', 'BlinkMacSystemFont', sans-serif;
  font-size: 9px;
  font-weight: 300;
  color: var(--dim);
  line-height: 1.55;
  margin-bottom: 10px;
}

.page-rule {
  border: none;
  border-top: 0.5px solid var(--border);
  margin-bottom: 12px;
}

/* Body text */
.body-text {
  font-family: 'Poppins', 'SF Pro Display', '-apple-system', 'BlinkMacSystemFont', sans-serif; font-family: 'Poppins', 'SF Pro Display', '-apple-system', 'BlinkMacSystemFont', sans-serif;
  font-size: 9.5px;
  font-weight: 300;
  color: var(--mid);
  line-height: 1.82;
  margin-bottom: 10px;
}
.body-text strong { color: var(--ink); font-weight: 500; }

/* Pull quote */
.pull-quote {
  background: var(--box-bg);
  border-left: 3px solid var(--violet);
  padding: 10px 12px;
  margin: 8px 0;
  border-radius: 0 4px 4px 0;
}
.pull-quote p {
  font-family: 'Lora', 'Georgia', 'Times New Roman', serif;
  font-style: italic;
  font-size: 9.5px;
  color: var(--mid);
  line-height: 1.8;
}

/* Insight box */
.insight-box {
  border: 1px solid var(--violet-light);
  border-radius: 6px;
  padding: 10px 12px;
  margin: 8px 0;
  background: var(--box-bg);
}
.insight-label {
  font-family: 'Poppins', 'SF Pro Display', '-apple-system', 'BlinkMacSystemFont', sans-serif; font-family: 'Poppins', 'SF Pro Display', '-apple-system', 'BlinkMacSystemFont', sans-serif;
  font-size: 7px;
  font-weight: 600;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--violet);
  margin-bottom: 5px;
}
.insight-text {
  font-family: 'Poppins', 'SF Pro Display', '-apple-system', 'BlinkMacSystemFont', sans-serif; font-family: 'Poppins', 'SF Pro Display', '-apple-system', 'BlinkMacSystemFont', sans-serif;
  font-size: 9px;
  font-weight: 300;
  color: var(--mid);
  line-height: 1.75;
}

/* Term box */
.term-box {
  border: 1px solid var(--violet-light);
  border-radius: 8px;
  padding: 14px 14px 12px;
  background: var(--box-bg);
  margin: 6px 0;
  position: relative;
  overflow: hidden;
  text-align: center;
}
.term-box::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: var(--violet);
  border-radius: 8px 8px 0 0;
}
.term-symbol { font-size: 18px; margin-bottom: 4px; display: block; }
.term-name { font-family: 'Lora', 'Georgia', 'Times New Roman', serif; font-size: 14px; color: var(--ink); margin-bottom: 2px; }
.term-rule { border: none; border-top: 0.4px solid var(--border); margin: 4px 20px; }
.term-english { font-size: 8px; font-weight: 300; color: var(--dim); }
.term-pron { font-size: 8px; font-weight: 300; color: var(--dim); margin-bottom: 6px; display: block; }
.term-def { font-size: 8.5px; font-weight: 300; color: var(--mid); line-height: 1.75; text-align: left; margin-top: 6px; }

/* Interlude / closing */
.interlude-page .page-inner {
  align-items: center;
  justify-content: center;
  text-align: center;
  gap: 10px;
}
.interlude-geo { width: 90px; height: 90px; margin: 0 auto; }
.interlude-title {
  font-family: 'Lora', 'Georgia', 'Times New Roman', serif;
  font-size: 18px;
  color: var(--ink);
  line-height: 1.3;
}
.interlude-title em { font-style: italic; }
.interlude-body {
  font-family: 'Poppins', 'SF Pro Display', '-apple-system', 'BlinkMacSystemFont', sans-serif; font-family: 'Poppins', 'SF Pro Display', '-apple-system', 'BlinkMacSystemFont', sans-serif;
  font-size: 9px;
  font-weight: 300;
  color: var(--mid);
  line-height: 1.8;
  max-width: 260px;
}
.interlude-rule { width: 32px; border: none; border-top: 0.5px solid var(--border); }
.interlude-quote {
  font-family: 'Lora', 'Georgia', 'Times New Roman', serif;
  font-style: italic;
  font-size: 9.5px;
  color: var(--mid);
  line-height: 1.8;
  max-width: 240px;
}

/* Closing page */
.closing-page .page-inner {
  align-items: center;
  justify-content: center;
  text-align: center;
  gap: 8px;
}
.closing-intro { font-family: 'Lora', 'Georgia', 'Times New Roman', serif; font-style: italic; font-size: 9.5px; color: var(--mid); line-height: 1.8; }
.closing-title { font-family: 'Lora', 'Georgia', 'Times New Roman', serif; font-size: 20px; color: var(--ink); line-height: 1.2; margin: 2px 0; }
.closing-title em { font-style: italic; }
.closing-circle {
  width: 18px; height: 18px;
  border: 2px solid var(--violet);
  border-radius: 50%;
  display: inline-block;
  vertical-align: middle;
  margin-left: 8px;
  opacity: 0.8;
}
.closing-sub { font-family: 'Lora', 'Georgia', 'Times New Roman', serif; font-style: italic; font-size: 9px; color: var(--mid); line-height: 1.7; }
.closing-rule { width: 40px; border: none; border-top: 0.5px solid var(--border); }
.closing-stinger { font-family: 'Lora', 'Georgia', 'Times New Roman', serif; font-style: italic; font-size: 9px; color: var(--mid); line-height: 1.85; }
.closing-conclusion { font-family: 'Lora', 'Georgia', 'Times New Roman', serif; font-size: 11px; color: var(--ink); }
.closing-byline { font-size: 7px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--dim); }
.closing-author { font-size: 9px; font-weight: 300; color: var(--mid); }

/* Chapter geo */
.chapter-geo { width: 52px; height: 52px; margin-bottom: 8px; }

/* Item list */
.item-list { display: flex; flex-direction: column; gap: 6px; margin: 6px 0; }
.item-key { font-size: 9px; font-weight: 600; color: var(--violet); margin-bottom: 1px; }
.item-desc { font-size: 8.5px; font-weight: 300; color: var(--mid); line-height: 1.7; }

/* Page number */
.page-num {
  position: absolute;
  bottom: 12px;
  width: 100%;
  text-align: center;
  font-size: 7px;
  color: var(--dim);
  font-family: 'Poppins', 'SF Pro Display', '-apple-system', 'BlinkMacSystemFont', sans-serif; font-family: 'Poppins', 'SF Pro Display', '-apple-system', 'BlinkMacSystemFont', sans-serif;
  letter-spacing: 0.1em;
  opacity: 0.5;
}

/* Geo SVGs */
svg.geo { width: 100%; height: 100%; }

/* Touch hint */
.touch-hint {
  position: fixed;
  bottom: 52px;
  left: 50%;
  transform: translateX(-50%);
  color: rgba(255,255,255,0.25);
  font-size: 9px;
  letter-spacing: 0.1em;
  font-family: 'Poppins', 'SF Pro Display', '-apple-system', 'BlinkMacSystemFont', sans-serif; font-family: 'Poppins', 'SF Pro Display', '-apple-system', 'BlinkMacSystemFont', sans-serif;
  white-space: nowrap;
}

@media (max-width: 600px) {
  .book { width: 300px; height: 450px; }
  .page { width: 300px; height: 450px; }
  .page-inner { padding: 28px 22px 24px; }
  .nav-prev { left: 8px; }
  .nav-next { right: 8px; }
}
</style>

<script>
// Generate cover thumbnail for sharing
function generateThumbnail() {
  const canvas = document.createElement('canvas');
  canvas.width = 1200; canvas.height = 630;
  const ctx = canvas.getContext('2d');

  // Background
  ctx.fillStyle = '#080B12';
  ctx.fillRect(0, 0, 1200, 630);

  // Border
  ctx.fillStyle = '#0D0B1A';
  ctx.fillRect(0, 0, 1200, 630);
  ctx.fillStyle = '#080B12';
  ctx.fillRect(24, 24, 1152, 582);

  // Violet accent border line
  ctx.strokeStyle = 'rgba(123, 47, 190, 0.3)';
  ctx.lineWidth = 1;
  ctx.strokeRect(28, 28, 1144, 574);

  const cx = 600, cy = 315;

  // Draw flower of life mandala
  const drawCircle = (x, y, r, alpha) => {
    ctx.beginPath();
    ctx.arc(x, y, r, 0, Math.PI * 2);
    ctx.strokeStyle = `rgba(123, 47, 190, ${alpha})`;
    ctx.lineWidth = 1.2;
    ctx.stroke();
  };

  const R = 130;
  drawCircle(cx, cy, R * 1.7, 0.15);
  drawCircle(cx, cy, R, 0.5);
  for (let a = 0; a < 360; a += 60) {
    const rad = a * Math.PI / 180;
    drawCircle(cx + R * Math.sin(rad), cy + R * Math.cos(rad), R, 0.4);
  }

  // Triangles
  ctx.strokeStyle = 'rgba(123, 47, 190, 0.65)';
  ctx.lineWidth = 1.8;
  [[0, R*1.72, R*1.49, -R*0.86, -R*1.49, -R*0.86],
   [0, -R*1.72, R*1.49, R*0.86, -R*1.49, R*0.86]].forEach(([x1,y1,x2,y2,x3,y3]) => {
    ctx.beginPath();
    ctx.moveTo(cx+x1, cy+y1);
    ctx.lineTo(cx+x2, cy+y2);
    ctx.lineTo(cx+x3, cy+y3);
    ctx.closePath(); ctx.stroke();
  });

  // Centre dot
  ctx.fillStyle = 'rgba(123, 47, 190, 0.9)';
  ctx.beginPath(); ctx.arc(cx, cy, 6, 0, Math.PI * 2); ctx.fill();

  // Text
  ctx.textAlign = 'center';
  ctx.fillStyle = 'rgba(237, 233, 228, 0.4)';
  ctx.font = '300 13px Poppins, sans-serif';
  ctx.letterSpacing = '0.3em';
  ctx.fillText('AYURVEDA  ·  SELF MASTERY  ·  EVOLUTION', cx, cy - 210);

  ctx.fillStyle = '#EDE9E4';
  ctx.font = '400 58px Lora, Georgia, serif';
  ctx.fillText('You Are Not Broken.', cx, cy + 210);

  ctx.font = 'italic 400 58px Lora, Georgia, serif';
  ctx.fillStyle = 'rgba(237, 233, 228, 0.6)';
  ctx.fillText('You Are Whole.', cx, cy + 280);

  ctx.fillStyle = 'rgba(154, 150, 144, 0.7)';
  ctx.font = '300 16px Poppins, sans-serif';
  ctx.fillText('chandanni miglino', cx, cy + 330);

  return canvas.toDataURL('image/png');
}
</script>
</head>
